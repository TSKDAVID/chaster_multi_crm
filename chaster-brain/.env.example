CHASTER_BRAIN_ENV=development
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Fast model for intent routing only (short JSON). Main answers still use GROQ_MODEL.
# Alternatives: llama-3.1-8b-instant (cheap), meta-llama/llama-4-scout-17b-16e-instruct (preview).
GROQ_INTENT_MODEL=openai/gpt-oss-20b
SIGNATURE_MAX_AGE_SECONDS=300
# Local dev only: when set, requests with header X-Chaster-Dev-Secret matching this value skip JWT verification (HMAC/origin still required). Leave unset in production.
CHASTER_BRAIN_DEV_GATEWAY_SECRET=
# Comma-separated for local/staging/prod. Example for production with a GitHub Pages frontend:
# CORS_ALLOW_ORIGINS=https://your-user.github.io,https://your-user.github.io/atomic-crm,https://staging.example.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080
WIDGET_SESSION_SECRET=dev-widget-session-secret-change-me
WIDGET_SESSION_TTL_SECONDS=900

# Optional Redis URL. Leave blank to use the in-process cache fallback for
# local dev. Render auto-injects this when you use the bundled render.yaml.
REDIS_URL=

# Memory manager tuning (defaults are safe).
MEMORY_RECENT_TURNS=8
MEMORY_COMPRESS_AFTER_MESSAGES=16
MEMORY_COMPRESS_TOKEN_BUDGET=1800
MEMORY_SUMMARY_TTL_SECONDS=86400
MEMORY_HOT_TTL_SECONDS=1800
INTENT_CACHE_TTL_SECONDS=600
FAQ_CACHE_TTL_SECONDS=300
RUNTIME_CACHE_TTL_SECONDS=60
PARAMETERS_CACHE_TTL_SECONDS=60
