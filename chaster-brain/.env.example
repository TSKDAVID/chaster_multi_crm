CHASTER_BRAIN_ENV=development
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
SIGNATURE_MAX_AGE_SECONDS=300
# Local dev only: when set, requests with header X-Chaster-Dev-Secret matching this value skip JWT verification (HMAC/origin still required). Leave unset in production.
CHASTER_BRAIN_DEV_GATEWAY_SECRET=
# Comma-separated for local/staging/prod. Example:
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://staging.example.com,https://app.example.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
WIDGET_SESSION_SECRET=dev-widget-session-secret-change-me
WIDGET_SESSION_TTL_SECONDS=900
