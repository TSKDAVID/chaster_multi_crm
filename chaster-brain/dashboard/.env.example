VITE_API_BASE_URL=http://127.0.0.1:8010
# Optional: same value as CHASTER_BRAIN_DEV_GATEWAY_SECRET on the API — pre-fills simulator dev secret (local only).
VITE_CHASTER_DEV_GATEWAY_SECRET=
