SKIP_PREFLIGHT_CHECK=true

# Public frontend variables (safe to expose in browser build)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SB_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
VITE_IS_DEMO=false
VITE_INBOUND_EMAIL=your-inbound-email@example.com
VITE_API_BASE_URL=https://your-chaster-brain-service.onrender.com
# Optional alias; if set, takes precedence over VITE_API_BASE_URL
# VITE_CHASTER_BRAIN_API_URL=https://your-chaster-brain-service.onrender.com

# Local/test checkout simulation only (keep real value in private env files)
VITE_CHASTER_PROVISIONING_SECRET=replace_with_local_or_staging_secret

VITE_ATTACHMENTS_BUCKET=attachments
